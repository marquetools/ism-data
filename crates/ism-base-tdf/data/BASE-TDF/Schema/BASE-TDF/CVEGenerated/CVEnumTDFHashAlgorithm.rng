<?xml version="1.0" encoding="UTF-8"?>
<!--UNCLASSIFIED-->
<grammar xmlns="http://relaxng.org/ns/structure/1.0"
         ns="urn:us:gov:ic:cvenum:tdf:hashalgorithm">
   <define name="CVEnumTDFHashAlgorithm.cve">
      <choice>
         <value>SHA1</value>
         <value>SHA256</value>
         <value>SHA384</value>
         <value>SHA512</value>
      </choice>
   </define>
</grammar>
