    <IRM>
        <URN>urn:us:gov:ic:cvenum:tdf:hashalgorithm</URN>
        <Title ism:ownerProducer="USA" ism:classification="U">CVEnumTDFHashAlgorithm</Title>
        <Description ism:ownerProducer="USA" ism:classification="U">All valid algorithms and patterns for hash algorithm for use with BindingValueType.</Description>
        <cve:Created xmlns:cve="urn:us:gov:ic:cve">2012-06-27T11:19:00-04:00</cve:Created>

        <cve:Source ism:classification="U" ism:ownerProducer="USA">IC-CIO</cve:Source>
        <cve:PointOfContact ism:classification="U" ism:ownerProducer="USA">
            <Name>Office IC CIO</Name>
            <Email>ic-standards-support@odni.gov</Email>
        </cve:PointOfContact>
    </IRM>

    <Enumeration multivalue="false" ism:ownerProducer="USA" ism:classification="U">

        <Term ism:classification="U" ism:ownerProducer="USA">
            <Value ism:classification="U" ism:ownerProducer="USA">SHA1</Value>
            <Description ism:classification="U" ism:ownerProducer="USA">Secure Hash Algorithm (SHA) with a 160 bit message digest. SHA-1 is the most widely used of the existing SHA hash functions, and is employed in several widely used applications and protocols.
			</Description>
        </Term>

        <Term ism:classification="U" ism:ownerProducer="USA">
            <Value ism:classification="U" ism:ownerProducer="USA">SHA256</Value>
            <Description ism:classification="U" ism:ownerProducer="USA">Secure Hash Algorithm (SHA) with a 256 bit message digest. 
   		    </Description>
        </Term>


        <Term ism:classification="U" ism:ownerProducer="USA">
            <Value ism:classification="U" ism:ownerProducer="USA">SHA384</Value>
            <Description ism:classification="U" ism:ownerProducer="USA">Secure Hash Algorithm (SHA) with a 384 bit message digest. 
   	        </Description>
        </Term>


        <Term ism:classification="U" ism:ownerProducer="USA">
            <Value ism:classification="U" ism:ownerProducer="USA">SHA512</Value>
            <Description ism:classification="U" ism:ownerProducer="USA">Secure Hash Algorithm (SHA) with a 512 bit message digest.
   	        </Description>
        </Term>

    </Enumeration>
</CVE>
