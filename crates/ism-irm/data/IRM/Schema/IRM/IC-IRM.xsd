            </xsd:documentation>
        </xsd:annotation>
        <xsd:simpleContent>
            <xsd:extension base="irm:simpleTokenType">
                <xsd:attribute name="dateProcessed" type="irm:CombinedDateType" use="required">
                    <xsd:annotation>
                        <xsd:documentation>
                            <xhtml:p ism:classification="U"
