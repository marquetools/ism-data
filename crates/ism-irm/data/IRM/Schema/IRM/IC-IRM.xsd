                     data-ded="ded:Comment">ded:Comment: This element must contain one or more name, region, countryCode,
                    subDivisionCode, facilityIdentifier or waterBody elements.</xhtml:p>
            </xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
            <xsd:choice maxOccurs="unbounded">
                <xsd:element name="name" type="irm:simpleTokenType">
                    <xsd:annotation>
