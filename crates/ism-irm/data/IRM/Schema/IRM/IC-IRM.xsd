                            <xhtml:p ism:classification="U"
                              ism:ownerProducer="USA"
                              data-ded="ded:Comment"/>
                        </xsd:documentation>
                    </xsd:annotation>
                </xsd:attribute>
                <xsd:attributeGroup ref="irm:SecurityAttributesGroup"/>
            </xsd:extension>
        </xsd:simpleContent>
    </xsd:complexType>

    <xsd:complexType name="ProducerBaseType">
