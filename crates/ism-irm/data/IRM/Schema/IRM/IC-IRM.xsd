    <xsd:element name="geographicIdentifier">
        <xsd:annotation>
            <xsd:documentation>
                <xhtml:p ism:classification="U"
                     ism:ownerProducer="USA"
                     data-ded="ded:Definition">ded:Definition: An element under geospatialCoverage that defines an identifier
