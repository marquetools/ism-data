                     <xsd:documentation>Other positive intel. Must be the string 'other:' followed by the value specifying the other positive intelligence code.</xsd:documentation>
                  </xsd:annotation>
               </xsd:pattern>
            </xsd:restriction>
         </xsd:simpleType>
         <xsd:simpleType>
            <xsd:restriction base="xsd:token">
