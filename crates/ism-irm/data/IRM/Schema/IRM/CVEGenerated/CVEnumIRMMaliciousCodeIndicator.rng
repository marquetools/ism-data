<?xml version="1.0" encoding="UTF-8"?>
<!--UNCLASSIFIED-->
<grammar xmlns="http://relaxng.org/ns/structure/1.0"
         ns="urn:us:gov:ic:cvenum:irm:maliciouscodeindicator">
   <define name="CVEnumIRMMaliciousCodeIndicator.cve">
      <choice>
         <value>MaliciousCodeFound</value>
         <value>MaliciousCodeNotFound</value>
         <value>SuspiciousIndicatorsFound</value>
         <value>Unevaluated</value>
      </choice>
   </define>
</grammar>
