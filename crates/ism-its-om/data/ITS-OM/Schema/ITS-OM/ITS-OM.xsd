    <!--
		The ICMS schema defines the elements for routing message objects within ITS.  
		In addition to the message contents and any attachments, it contains other metadata such as the originator, recipient(s), security markings and delivery precedence.	
	-->
    <!--
		Global Elements
	-->
    <xsd:element name="Icms" type="icms:IcmsType">
        <xsd:annotation>
            <xsd:documentation>Intelligence Community Messaging Service</xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="Forward" type="icms:ForwardType">
        <xsd:annotation>
            <xsd:documentation>
                <xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >The Forward element provides information for a received Icms/Message to be
                    forwarded to additional recipients. </xhtml:p>
            </xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="Message" type="icms:MessageType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U">The Message element provides information about
                    the message including: <xhtml:ul >
                        <xhtml:li ism:ownerProducer="USA" ism:classification="U"
                            >security labels and address space</xhtml:li>
                        <xhtml:li ism:ownerProducer="USA" ism:classification="U"
                            >identification number, subject, client
                            and originator dates</xhtml:li>
                        <xhtml:li ism:ownerProducer="USA" ism:classification="U"
                            >originator and recipients</xhtml:li>
                        <xhtml:li ism:ownerProducer="USA" ism:classification="U"
                            >precedence(s)</xhtml:li>
                        <xhtml:li ism:ownerProducer="USA" ism:classification="U"
                            >special handling instructions</xhtml:li>
                        <xhtml:li ism:ownerProducer="USA" ism:classification="U"
                            >content including body and
                            attachments</xhtml:li>
                    </xhtml:ul>The Message element has the IC ISM security attribute group,
                    ResourceNodeAttributeGroup, which identifies Message as the primary resource
                    element of ICMS XML. The Message element’s security attributes are used to
                    provide the organizational message’s security markings.  This security marking
                    should represent the highest overall classification of the message taking into
                    account any security attributes which exist on the elements for Subject, Body,
                    and/or Attachment elements. </xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="IcmsDateReleased" type="xsd:dateTime">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >IcmsDateReleased is a mandatory element of type
                    xsd:dateTime. This is the Greenwich Mean Time of the date and time the message
                    was released by the ITS/OM Client.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="IcmsMessageId" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >The IcmsMessageId element is the required
                    Universal Unique Identifier (UUID) assigned when the message is released.  This
                    is the message identifier used throughout the IC ITS to track the message. The
                    UUID should be built as specified RFC 4122.  Most application development
                    languages have libraries which support the creation of a UUID based on the
                    specific server information and the current date and
                time.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="OrigMessageID" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >The optional element, OrigMessageID, provides a
                    field for an originating client to include a local identifier assigned to the
                    message.  It is of type xsd:string and multiple elements may be
                included.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="OriginatorDateAssigned" type="xsd:dateTime">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >OriginatorDateAssigned is an optional element
                    of type xsd:dateTime. This is the date and time assigned to the message by the
                    originator.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="Topic" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >The optional element, Topic, provides a field
                    for indicating the general topic of the message. It is of type xsd:string and
                    multiple elements may be included.  This element is planned for future
                use.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="AddressSpace" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                >The Address Space of the message (DSSCS, GENSER, SOCOMM,
                etc.)</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="PrecedenceList" type="icms:PrecedenceListType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >The PrecedenceList element provides the
                    precedence values at which the message(s) or forwarded delivery(s) should be
                    made.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="Originator" type="icms:OriginatorType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >The Originator element provides the necessary
                    information about the originator of the message.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="RecipientList" type="icms:RecipientListType">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >The element, RecipientList, contains one or more Recipient elements.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="SpecialHandling" type="icms:SpecialHandlingType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >Additional information specific to the delivery
                    processing of this message, such as additional legacy format values for use if
                    the message transits the LTG.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="Subject" type="icms:SubjectType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >The required element, Subject, contains the
                    subject or description of the message content.  The Subject element has the IC
                    ISM security attribute, SecurityAttributesOptionGroup.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="BodyList" type="icms:BodyListType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                >List of body elements</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="AttachmentList" type="icms:AttachmentListType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                >List of attachments</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <!-- 
		Message Global Elements  
	-->
    <xsd:element name="ToPrecedence" type="icms:PrecedenceType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                >The TO recipients delivery precedence</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="CcPrecedence" type="icms:PrecedenceType">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                >The CC recipients delivery precedence</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="OfficeCodes" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation><xhtml:p ism:ownerProducer="USA" ism:classification="U"
                    >This element can be used to identify the office
                    within the associated organization which is to receive this message. The element
                    is optional, but may also exist multiple times if multiple offices within the
                    same organization should receive the message.</xhtml:p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="Recipient" type="icms:RecipientType">
        <xsd:annotation>
            <xsd:documentation>The recipient of the message. At least one recipient is
                required.</xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="OrgName" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element is required and contains the
                    organizational address of the recipient or the address list name for a group of
                    organizational addresses which should receive the
                message.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="RecpType" type="icms:RecpTypeType">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element is required and identifies the
                    type of recipient.  It is one of TO, CC, EXCLUDE, TO_ZEN, or CC_ZEN.  The TO
                    value indicates the recipient should receive a copy at the message’s associated
                    action precedence (Message.PrecedenceList.ToPrecedence) while the CC value
                    indicates the recipient should receive a copy at the message’s associated info
                    precedence (Message.PrecedenceList.CcPrecedence).  The EXCLUDE value indicates
                    the recipient is a member of a group which should not receive a copy of the
                    message and should only be used when the OrgType is GroupMember.  The TO_ZEN and
                    CC_ZEN values indicate the recipient should not receive a copy of the message
                    because that copy was delivered to that recipient outside the organizational
                    messaging systems.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="OrgType" type="icms:OrgTypeType">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element is required and indicates the type
                    of organization provided in the OrgName element.  It is one of PLA, Group, or
                    GroupMember.  PLA indicates the value is an individual recipient identified by
                    its plain language address.  Group indicates the value is a group name
                    identifying multiple recipients by their membership in the group.  GroupMember
                    indicates the value is the plain language address of an address group member.
                     GroupMember should only be used when the recipient list also includes an
                    OrgType of Group.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="OrgClient" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element is used to identify the ITS Client
                    which provides the delivery path to the recipient.  If the RecpType is EXCLUDE,
                    TO_ZEN, or CC_ZEN, this element is not necessary since no delivery will be made
                    to this type of recipient.  If the OrgType is Group, this element is not
                    necessary since deliveries are made to group members and not the group itself.
                     If the RecpType is TO or CC and the OrgType is PLA or GroupMember, this element
                    if it exists contains the ITS Client ID of the Client which provides the
                    organization’s messaging support.  More than one OrgClient element may exist if
                    more than one ITS Client receives messages for the associated
                organization.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="ReceiptRequested" type="xsd:boolean" default="false">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element is optional and can be used to
                    indicate to a recipient that the originator requests acknowledge that the
                    message has been read. It is a Boolean element and should be set to true or
                    false.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="Attachment" type="icms:AttachmentType">
        <xsd:annotation>
            <xsd:documentation>The attachment and its metadata. An attachment may have security
                markings.</xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="AttachmentName" type="icms:AttachmentNameType">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element contains the name of the
                    attachment (please limit to 256 char) along with the mime-type attribute which
                    identifies the content type using the MIME media type values found in RFC 2046.
                     An ITS Client may originate any attachment type defined within the
                    specification.  A minimum set of file types should be recognized by a consuming
                    ITS Client. This minimum set is also the only file types allowed to cross a
                    security domain.  Within a single security domain other files types are allowed
                    as long as the originating Client and receiving Client are in agreement on the
                    handling of the attachment.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="AttachmentDescription" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element is optional and may contain a
                    textual description of the attachment contents.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="AttachmentSize" type="xsd:double">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element contains the size in bytes. If the
                    attachment content is included in the element, AttachmentData, this represents
                    the size of the attachment after any conversion and compression actions are
                    applied to its contents.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="AttachmentLocation" type="xsd:anyURI">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element can be used to provide the URI of
                    where the attachment can be found. AttachmentLocation should not be used when
                    the AttachmentData element is used.</p></xsd:documentation>
        </xsd:annotation>
    </xsd:element>
    <xsd:element name="AttachmentData">
        <xsd:annotation>
            <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                    >This element can contain the actual data either
                    base64 encoded or zipped and then base64 encoded. The associated attribute,
                    composition, identifies which method was used to encode the data. The
                    composition attribute should contain “base64” or “zip:base64”. AttachmentData
                    should not be used when the AttachmentLocation element is
                used.</p></xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
            <xsd:simpleContent>
                <xsd:extension base="xsd:base64Binary">
                    <xsd:attribute ref="icms:composition" use="required"/>
                </xsd:extension>
            </xsd:simpleContent>
        </xsd:complexType>
    </xsd:element>
    <!--
		Type Definitions
	-->
    <xsd:complexType name="IcmsType">
        <xsd:sequence>
            <xsd:element ref="icms:Forward" minOccurs="0"/>
            <xsd:element ref="icms:Message"/>
        </xsd:sequence>
        <xsd:attributeGroup ref="ism:ISMRootNodeAttributeGroup"/>
    </xsd:complexType>
    <xsd:complexType name="ForwardType">
        <xsd:sequence>
            <xsd:element name="DateTime" type="xsd:dateTime">
                <xsd:annotation>
                    <xsd:documentation>
                        <p ism:ownerProducer="USA" ism:classification="U"
                            >The DateTime element should be set to
                            the date and time the ITS Client releases the forwarded message to
                            ITS.</p></xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element ref="icms:IcmsMessageId"/>
            <xsd:element name="Reason" type="xsd:string" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                            >The Reason element is optional and can
                            be set to a text string explaining the reason this message is being
                            forwarded.</p></xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element ref="icms:PrecedenceList">
                <xsd:annotation>
                    <xsd:documentation>The forwarding precedence</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element ref="icms:Originator">
                <xsd:annotation>
                    <xsd:documentation>The forwarding originator</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element ref="icms:RecipientList">
                <xsd:annotation>
                    <xsd:documentation>The recipients of the forwarded message</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element name="PreviousForward" type="icms:ForwardType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation><p ism:ownerProducer="USA" ism:classification="U"
                            >The PreviousForward element contains
                            the current forward element when a new forward element is created to
                            forward an Icms message which already has a Forward
                        element.</p></xsd:documentation>
                </xsd:annotation>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="MessageType">
        <xsd:sequence>
            <xsd:element ref="icms:IcmsDateReleased"/>
            <xsd:element ref="icms:IcmsMessageId"/>
            <xsd:element ref="icms:OrigMessageID" minOccurs="0" maxOccurs="unbounded"/>
            <xsd:element ref="icms:OriginatorDateAssigned" minOccurs="0"/>
            <xsd:element ref="icms:AddressSpace"/>
            <xsd:element ref="icms:Topic" minOccurs="0" maxOccurs="unbounded"/>
            <xsd:element ref="icms:PrecedenceList"/>
            <xsd:element ref="icms:Originator"/>
            <xsd:element ref="icms:RecipientList"/>
            <xsd:element ref="icms:SpecialHandling" minOccurs="0" maxOccurs="unbounded"/>
            <xsd:element ref="icms:Subject"/>
            <xsd:element ref="icms:BodyList" minOccurs="0"/>
            <xsd:element ref="icms:AttachmentList" minOccurs="0"/>
        </xsd:sequence>
        <xsd:attributeGroup ref="ism:ResourceNodeAttributeGroup"/>
    </xsd:complexType>
    <xsd:complexType name="PrecedenceListType">
        <xsd:choice>
            <xsd:sequence>
                <xsd:element ref="icms:ToPrecedence"/>
                <xsd:element ref="icms:CcPrecedence" minOccurs="0"/>
            </xsd:sequence>
            <xsd:sequence>
                <xsd:element ref="icms:CcPrecedence"/>
                <xsd:element ref="icms:ToPrecedence" minOccurs="0"/>
            </xsd:sequence>
        </xsd:choice>
    </xsd:complexType>
    <xsd:simpleType name="PrecedenceType">
        <xsd:restriction base="xsd:NMTOKEN">
            <xsd:enumeration value="CRITIC"/>
            <xsd:enumeration value="ECP"/>
            <xsd:enumeration value="FLASH"/>
            <xsd:enumeration value="IMMEDIATE"/>
            <xsd:enumeration value="PRIORITY"/>
            <xsd:enumeration value="ROUTINE"/>
        </xsd:restriction>
    </xsd:simpleType>
    <xsd:complexType name="OriginatorType">
        <xsd:sequence>
            <xsd:element ref="icms:OrgName">
                <xsd:annotation>
                    <xsd:documentation>The organizational address of the
                        originator</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element ref="icms:OfficeCodes" minOccurs="0" maxOccurs="unbounded"/>
            <xsd:element name="ReleaserName" type="xsd:string" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation> The name of the release authority for this
                        object</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="RecipientListType">
        <xsd:sequence>
            <xsd:element ref="icms:Recipient" maxOccurs="unbounded"/>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="RecipientType">
        <xsd:sequence>
            <xsd:element ref="icms:RecpType"/>
            <xsd:element ref="icms:OrgName">
                <xsd:annotation>
                    <xsd:documentation>The organizational address of the
                        recipient</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element ref="icms:OfficeCodes" minOccurs="0" maxOccurs="unbounded"/>
            <xsd:element ref="icms:OrgType">
                <xsd:annotation>
                    <xsd:documentation>The organizational address type: PLA, Group, or
                        GroupMember</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element ref="icms:OrgClient" minOccurs="0" maxOccurs="unbounded">
                <xsd:annotation>
                    <xsd:documentation>The ITS client ID supporting this Recipient. Depending on
                        Recipient's delivery requirements, this element may not exist at all or
                        contains the ITS Client providing delivery to the Recipient. More than one
                        element is allowed when more than one ITS client provides delivery for this
                        Recipient</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element ref="icms:ReceiptRequested" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>If the recipient is requested to send back a read
                        receipt</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
        </xsd:sequence>
        <xsd:attribute name="Dual-Rcv" type="xsd:boolean" use="optional" default="false">
            <xsd:annotation>
                <xsd:documentation>This attribute is used to indicate the Recipient element is a
                    duplicate entry for use in the dual receive testing process.</xsd:documentation>
            </xsd:annotation>
        </xsd:attribute>
    </xsd:complexType>
    <xsd:simpleType name="RecpTypeType">
        <xsd:restriction base="xsd:NMTOKEN">
            <xsd:enumeration value="TO"/>
            <xsd:enumeration value="CC"/>
            <xsd:enumeration value="EXCLUDE"/>
            <xsd:enumeration value="TO_ZEN"/>
            <xsd:enumeration value="CC_ZEN"/>
        </xsd:restriction>
    </xsd:simpleType>
    <xsd:simpleType name="OrgTypeType">
        <xsd:restriction base="xsd:NMTOKEN">
            <xsd:enumeration value="PLA"/>
            <xsd:enumeration value="Group"/>
            <xsd:enumeration value="GroupMember"/>
        </xsd:restriction>
    </xsd:simpleType>
    <xsd:complexType name="SpecialHandlingType">
        <xsd:sequence>
            <xsd:any processContents="lax" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>Import applicable special handling xsd</xsd:documentation>
                </xsd:annotation>
            </xsd:any>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="SubjectType">
        <xsd:simpleContent>
            <xsd:extension base="xsd:string">
                <xsd:attributeGroup ref="ism:SecurityAttributesOptionGroup"/>
            </xsd:extension>
        </xsd:simpleContent>
    </xsd:complexType>
    <xsd:complexType name="BodyListType">
        <xsd:sequence>
            <xsd:element name="Body" type="icms:BodyType" maxOccurs="unbounded">
                <xsd:annotation>
                    <xsd:documentation>The message body contents. Each BodyElement can have its own
                        security markings.</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="BodyType">
        <xsd:sequence>
            <xsd:any processContents="lax" minOccurs="0"/>
        </xsd:sequence>
        <xsd:attributeGroup ref="ism:SecurityAttributesOptionGroup"/>
        <xsd:attribute ref="icms:title" use="optional"/>
    </xsd:complexType>
    <xsd:complexType name="AttachmentListType">
        <xsd:sequence>
            <xsd:element ref="icms:Attachment" maxOccurs="unbounded"/>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="AttachmentType">
        <xsd:sequence>
            <xsd:element ref="icms:AttachmentName"/>
            <xsd:element ref="icms:AttachmentDescription" minOccurs="0"/>
            <xsd:element ref="icms:AttachmentSize"/>
            <xsd:choice>
                <xsd:element ref="icms:AttachmentLocation"/>
                <xsd:element ref="icms:AttachmentData"/>
            </xsd:choice>
        </xsd:sequence>
        <xsd:attributeGroup ref="ism:SecurityAttributesOptionGroup"/>
    </xsd:complexType>
    <xsd:complexType name="AttachmentNameType">
        <xsd:simpleContent>
            <xsd:extension base="xsd:string">
                <xsd:attribute ref="icms:mime-type" use="required"/>
            </xsd:extension>
        </xsd:simpleContent>
    </xsd:complexType>
    <!-- 
		Attributes 
	-->
    <xsd:attribute name="DESVersion" type="ism:ShortStringType" fixed="2">
        <xsd:annotation>
            <xsd:documentation xml:lang="en">
                <xhtml:p ism:ownerProducer="USA" ism:classification="U"> The version number of the DES </xhtml:p>
            </xsd:documentation>
        </xsd:annotation>
    </xsd:attribute> 
    <xsd:attribute name="composition">
        <xsd:annotation>
            <xsd:documentation>This is a set of colon delimited file extension to show how the file
                was base 64 encoded. Enumerated values of zip:base64 or base64..</xsd:documentation>
        </xsd:annotation>
        <xsd:simpleType>
            <xsd:restriction base="xsd:string">
                <xsd:enumeration value="zip:base64"/>
                <xsd:enumeration value="base64"/>
            </xsd:restriction>
        </xsd:simpleType>
    </xsd:attribute>
    <xsd:attribute name="mime-type" type="xsd:string">
        <xsd:annotation>
            <xsd:documentation>The mine type of the attachment</xsd:documentation>
        </xsd:annotation>
    </xsd:attribute>
    <xsd:attribute name="title">
        <xsd:annotation>
            <xsd:documentation>A Title for the Body part </xsd:documentation>
        </xsd:annotation>
    </xsd:attribute>
