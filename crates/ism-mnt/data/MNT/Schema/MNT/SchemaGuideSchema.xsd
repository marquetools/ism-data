        <xsd:documentation>
            <xhtml:h2 ism:ownerProducer="USA" ism:classification="U">Implementation Notes</xhtml:h2>
            <xhtml:p ism:ownerProducer="USA" ism:classification="U">An MNT.XML instance is an
                instance starting with either the Issues or Regions root elements:</xhtml:p>
            <xhtml:ul>
                <xhtml:p ism:ownerProducer="USA" ism:classification="U">A <xhtml:a href="Issue_xsd_Element_issue_Issues.html#Issues">issue:Issues</xhtml:a>
                </xhtml:p>
                <xhtml:p ism:ownerProducer="USA" ism:classification="U">A <xhtml:a href="Region_xsd_Element_region_Regions.html#Regions">region:Regions</xhtml:a>
                </xhtml:p>
            </xhtml:ul>
        </xsd:documentation>
        <xsd:documentation>
            <xhtml:h2 ism:ownerProducer="USA" ism:classification="U">Creators</xhtml:h2>
