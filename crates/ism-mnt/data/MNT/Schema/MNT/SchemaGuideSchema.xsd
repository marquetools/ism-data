    <!-- Import the schema for each "dependent" spec. This schema is only used to generate a SchemaGuide -->

    <!-- PUBS schema because that is the main spec -->
    <xsd:import namespace="urn:us:gov:ic:taxonomy:mnt:issue" schemaLocation="Issue.xsd"/>

    <!-- TDF schema because PUBS goes inside a TDO now (TDF schema imports its dependencies) -->

    <!-- IRM SchemaGuideSchema because PUBS requires an IRM.
        The main IRM schema does not import its dependent schemas, but the IRM SchemaGuideSchema 
        does import those dependencies -->
    <!-- Currently, the PUBS schema imports the IRM schema (CG: I think this might be incorrect, though) -->
    <xsd:import namespace="urn:us:gov:ic:taxonomy:mnt:region"
               schemaLocation="Region.xsd"/>
</xsd:schema>
