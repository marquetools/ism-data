<!-- 
     Goal:  Failing test minimum value configuration for NTK Mission Need Access Profile
     Test Config File:       ../example_minvalues_config.xml
     Test Config Setting:    Comment out this config to force failure ...
                             <NtkAccessProfile type="minvalues"
                                             accessPolicy="urn:us:gov:ic:aces:ntk:mn">
                                ...
                             </NtkAccessProfile> 
     Expected Test Result:   FAIL
     Expected Error Message: WLNtkAccessProfileValue-ID-00002
     
     To run this test:
          1. copy contents of Test Config File to ../../Schematron/Whitelist/whitelist_config.xml

-->
<test:root xmlns:test="test:ntk"
           xmlns:ism="urn:us:gov:ic:ism"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           ism:compliesWith="USGov USIC"
           ism:resourceElement="true"
           ism:createDate="2012-05-28"
           ism:DESVersion="202111.202211"
           ism:ISMCATCESVersion="202211"
           ism:classification="U"
           ism:ownerProducer="USA"
           xsi:schemaLocation="test:ntk ../ISM/test_ntk.xsd">
  <arh:Security xmlns:arh="urn:us:gov:ic:arh"
                ism:classification="U"
                ism:ownerProducer="USA"
                ism:resourceElement="true"
                ism:compliesWith="USGov USIC"
                ism:createDate="2019-12-19">
    <ntk:Access xmlns:ntk="urn:us:gov:ic:ntk"
                ism:classification="U"
                ism:ownerProducer="USA">
      <ntk:RequiresAllOf>
        <ntk:AccessProfileList>
          <ntk:AccessProfile ism:classification="U"
                             ism:ownerProducer="USA">
            <ntk:AccessPolicy>urn:us:gov:ic:aces:ntk:mn</ntk:AccessPolicy>
            <ntk:ProfileDes>urn:us:gov:ic:ntk:profile:datasphere</ntk:ProfileDes>
            <ntk:VocabularyType ntk:name="datasphere:mn:issue"
                                ntk:sourceVersion="202111" />
            <ntk:VocabularyType ntk:name="datasphere:mn:region"
                                ntk:sourceVersion="202111" />
            <ntk:AccessProfileValue ntk:vocabulary="datasphere:mn:issue">DI</ntk:AccessProfileValue>
            <ntk:AccessProfileValue ntk:vocabulary="datasphere:mn:issue">WPW</ntk:AccessProfileValue>
            <ntk:AccessProfileValue ntk:vocabulary="datasphere:mn:region">AFea</ntk:AccessProfileValue>
            <ntk:AccessProfileValue ntk:vocabulary="datasphere:mn:region">AFno</ntk:AccessProfileValue>
          </ntk:AccessProfile>
        </ntk:AccessProfileList>
      </ntk:RequiresAllOf>
    </ntk:Access>
  </arh:Security>
</test:root>
