   <!--Start Import Statements-->
   <!--***************************************************-->
    <xsd:import namespace="http://www.w3.org/1999/xlink" schemaLocation="../w3/1999/xlink/xlink.xsd"/>
    <xsd:import namespace="urn:us:gov:ic:arh" schemaLocation="../ARH/IC-ARH.xsd">
        <xsd:annotation>
            <xsd:documentation>
                <xhtml:p ism:ownerProducer="USA" ism:classification="U">Import IC Access Rights and Handling (ARH) attributes</xhtml:p>
            </xsd:documentation>
        </xsd:annotation>
    </xsd:import>
    <xsd:import namespace="http://www.w3.org/1999/xlink" schemaLocation="../w3/1999/xlink/xlink.xsd"/>
    <xsd:import namespace="urn:us:gov:ic:ism" schemaLocation="../ISM/IC-ISM.xsd">
        <xsd:annotation>
            <xsd:documentation>
                <xhtml:p ism:ownerProducer="USA" ism:classification="U">Import IC Information Security Markings (ISM) attributes</xhtml:p>
            </xsd:documentation>
        </xsd:annotation>
    </xsd:import>
   <!--***************************************************-->
   <!--End Import Statements-->
   <!--***************************************************-->
   <!--***************************************************-->
   <!--Start All case-insensitive alphabetically-->
   <!--***************************************************-->
   
   <xsd:element name="Portion">
        <xsd:annotation>
            <xsd:documentation xml:lang="en">
            <xhtml:p ism:ownerProducer="USA" ism:classification="U">
                Contains the security metadata for any portion of the message.
                The element contains IC ISM attributes for the portion, and a reference
                to the portion that is being tagged.  The xlink:href attribute is used
                to reference the portion being tagged.
            </xhtml:p>
         </xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
            <xsd:attributeGroup ref="ism:SecurityAttributesGroup"/>				
            <xsd:attributeGroup ref="xlink:simpleAttrs"/>				
        </xsd:complexType>
    </xsd:element>
   
    <xsd:attribute name="DESVersion" type="ism:ShortStringType" fixed="2">
        <xsd:annotation>
            <xsd:documentation xml:lang="en">
                <xhtml:p ism:ownerProducer="USA" ism:classification="U"> The version number of the DES </xhtml:p>
            </xsd:documentation>
        </xsd:annotation>
    </xsd:attribute>
   
   <xsd:element name="SecurityMarkings">
        <xsd:annotation>
            <xsd:documentation xml:lang="en">
            <xhtml:p ism:ownerProducer="USA" ism:classification="U">
                Root node of the schema and contains all the mandatory and optional
                security metadata needed to mark a Request/Response message.
            </xhtml:p>
         </xsd:documentation>
        </xsd:annotation>
       <xsd:complexType>
           <xsd:sequence>
               <xsd:element ref="arh:Security" minOccurs="1" maxOccurs="1"/>
               <xsd:element ref="Portion" minOccurs="1" maxOccurs="unbounded"/>
           </xsd:sequence>
       </xsd:complexType>
   </xsd:element>
    
    
   <!--***************************************************-->
   <!--End All case-insensitive alphabetically-->
