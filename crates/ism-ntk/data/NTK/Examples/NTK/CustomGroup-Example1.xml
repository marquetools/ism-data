<test:root xmlns:test="test:ntk"
           xmlns:ism="urn:us:gov:ic:ism"
           xmlns:ntk="urn:us:gov:ic:ntk"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           ism:compliesWith="USGov USIC"
           ism:resourceElement="true"
           ntk:DESVersion="201508"
           ism:createDate="9999-11-11"
           ism:DESVersion="201609.201707"
           ism:ISMCATCESVersion="201709"
           ism:classification="U"
           ism:ownerProducer="USA"
           xsi:schemaLocation="test:ntk ./test_ntk.xsd">
   <ntk:Access ism:classification="U" ism:ownerProducer="USA">
      <ntk:RequiresAnyOf><!-- Sample file restricting use to the people in SourceForge who 
            Have the "SourceView" role in the "Data Standards Coordination Activity" project    -->
         <ntk:AccessProfileList>
            <ntk:AccessProfile ism:classification="U" ism:ownerProducer="USA">
               <ntk:AccessPolicy>UnclassSourceForge</ntk:AccessPolicy>
               <ntk:ProfileDes>guide://999990/exampleProfileDES</ntk:ProfileDes>
               <ntk:VocabularyType ntk:name="group:projectName" ntk:source="sourceforge:projects"/>
               <ntk:VocabularyType ntk:name="group:role" ntk:source="sorceforge:roles"/>
               <ntk:AccessProfileValue ntk:vocabulary="group:projectName">Data Standards Coordination Activity</ntk:AccessProfileValue>
               <ntk:AccessProfileValue ntk:vocabulary="group:role">SourceView</ntk:AccessProfileValue>
            </ntk:AccessProfile>
         </ntk:AccessProfileList>
      </ntk:RequiresAnyOf>
   </ntk:Access>
   <test:portion ism:classification="U" ism:ownerProducer="USA">An NTK portion</test:portion>
</test:root>
