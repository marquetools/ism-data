<cve:CVE xmlns:cve="urn:us:gov:ic:cve"
         xmlns:ism="urn:us:gov:ic:ism"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         
         ism:compliesWith="USGov USIC"
         ism:ownerProducer="USA"
         ism:classification="U"
         ism:DESVersion="202111"
         ism:ISMCATCESVersion="202205"
         ism:resourceElement="true"
         CVEVersion="2"
         ism:createDate="2015-02-25"
         xsi:schemaLocation="urn:us:gov:ic:cve ../CveSchema/CVEXml.xsd">

    <!-- Change Request #889 - Activity and Sub-Activity Elements  -->
    <cve:IRM>
        <URN xmlns="urn:us:gov:ic:cve">urn:us:gov:ic:cvenum:domex:CVEnumDOMEXActivityCommunications</URN>
        <Title xmlns="urn:us:gov:ic:cve"
             ism:ownerProducer="USA"
             ism:classification="U">CVEnumDOMEXActivityCommunications</Title>
        <Description xmlns="urn:us:gov:ic:cve"
                   ism:ownerProducer="USA"
                   ism:classification="U">Valid range for sub-activities.</Description>

        <cve:Created>2015-02-25</cve:Created>

        <Source ism:classification="U" ism:ownerProducer="USA" xmlns="urn:us:gov:ic:cve">Authoritative source for sub-activities</Source>
        <PointOfContact ism:classification="U" ism:ownerProducer="USA" xmlns="urn:us:gov:ic:cve">
         <Name>DOMEX Metadata Working Group</Name>
      </PointOfContact>
    </cve:IRM>
    
    <cve:Enumeration multivalue="false" ism:ownerProducer="USA" ism:classification="U">
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Actions</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Items in a communication channel</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Cryptography</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Encrypted items and encryption related software or training materials, includes steganography</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">FIS</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Items related to FIS communications</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Logistics</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Documents related to acquisition, storage and distribution of computers and/or communications resources</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Logo</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Communications items that have a logo or flag embedded</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Operations</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Items presenting a target group's operational use (trade craft) of computers and communications, things like SOPs, code books, call signs etc.</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Other</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">Misc items related to primary activity</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Planning</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">Planning with respect to target group's future computer acquisitions and employment</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">R&amp;D</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">R&amp;D related to a target groups computer and communications employment</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Reporting</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">Reporting related to communications operations and training</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Training</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">Computer and communications training materials created by target organization</Description>
        </cve:Term>
    </cve:Enumeration>
</cve:CVE>
