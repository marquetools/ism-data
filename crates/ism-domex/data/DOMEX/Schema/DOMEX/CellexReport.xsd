		    <xs:sequence>
			      <xs:element name="callLogEntry" type="cr:CallLogEntryType" maxOccurs="unbounded"/>
		    </xs:sequence>
	  </xs:complexType>
	  <xs:complexType name="CallLogEntryType">
		    <xs:all>
			      <xs:element name="index" type="xs:string" minOccurs="0">
