					          <xs:documentation> First 2 digits of the TAC. Identifies the GSMA-approved group
						that allocated the TAC. </xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="approvedIn" type="xs:string" minOccurs="0">
