					          <xs:documentation> Model of the electronic device </xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="tac" type="xs:string" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation> Type Allocation Code. Initial 8-digit portion of the IMEI.
					</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="reportingBody" type="xs:string" minOccurs="0">
