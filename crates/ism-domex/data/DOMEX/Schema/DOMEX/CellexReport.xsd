					          <xs:documentation> None provided </xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="bands" type="xs:string" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation> None provided </xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:all>
	  </xs:complexType>
	  <xs:complexType name="CellexReportDataType">
