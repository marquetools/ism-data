	  </xs:simpleType>
	  <xs:simpleType name="MemoryLocationType">
		    <xs:restriction base="xs:string">
			      <xs:enumeration value="Handset"/>
			      <xs:enumeration value="SIM"/>
			      <xs:enumeration value="ExtMemCard"/>
		    </xs:restriction>
	  </xs:simpleType>
	  <xs:complexType name="ImeiRecord">
		    <xs:all>
			      <xs:element name="make" type="xs:string" minOccurs="0">
