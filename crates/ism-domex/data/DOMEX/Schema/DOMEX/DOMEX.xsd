			      <xs:documentation> Details for a translation </xs:documentation>
		    </xs:annotation>
		    <xs:sequence>
			      <xs:element name="translationStatus"
                     type="CVEnumDOMEXTranslationStatusType:CVEnumDOMEXTranslationStatusType"
                     minOccurs="0">
