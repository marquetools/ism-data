    <xsd:simpleType name="SubjectTypeType">
        <xsd:list>
            <xsd:simpleType>
                <xsd:union>
                    <xsd:simpleType>
                        <xsd:restriction base="xsd:token">
                            <xsd:enumeration value="Logical"/>
                            <xsd:enumeration value="UML"/>
                            <xsd:enumeration value="Physical"/>
                            <xsd:enumeration value="Ontology"/>
                            <xsd:enumeration value="Database"/>
                            <xsd:enumeration value="XML"/>
                            <xsd:enumeration value="JSON"/>
                            <xsd:enumeration value="CSV"/>
                            <xsd:enumeration value="CVE"/>
                        </xsd:restriction>
                    </xsd:simpleType>
                    <xsd:simpleType>
                        <xsd:restriction base="xsd:token">
                            <xsd:pattern value="Other:.*"/>
                        </xsd:restriction>
                    </xsd:simpleType>
                </xsd:union>
            </xsd:simpleType>
        </xsd:list>
    </xsd:simpleType>
    
