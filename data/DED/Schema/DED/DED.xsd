            <xsd:element ref="ded:RelationshipComments" minOccurs="0" maxOccurs="1"/>
            <xsd:element ref="ded:RelationshipName" minOccurs="1" maxOccurs="1"/>
            <xsd:element ref="ded:RelationshipId" minOccurs="0" maxOccurs="1"/>
        </xsd:all>
        <!-- RelationshipAccessControl -->
        <xsd:attributeGroup ref="ism:SecurityAttributesGroup"/>
    </xsd:complexType>

    <xsd:complexType name="ElementRestrictionsType">
        <xsd:sequence>
            <xsd:element minOccurs="1" maxOccurs="unbounded" ref="ded:ElementRestriction"/>
        </xsd:sequence>
    </xsd:complexType>

    <xsd:complexType name="ElementCommentsType">
        <xsd:sequence>
            <xsd:element minOccurs="1" maxOccurs="unbounded" ref="ded:ElementComment"/>
        </xsd:sequence>
    </xsd:complexType>

    <xsd:complexType name="RelationshipCommentsType">
        <xsd:sequence>
            <xsd:element minOccurs="1" maxOccurs="unbounded" ref="ded:RelationshipComment"/>
        </xsd:sequence>
    </xsd:complexType>

    <xsd:simpleType name="ObligationEnumType">
        <xsd:restriction base="xsd:token">
            <xsd:enumeration value="Mandatory"/>
            <xsd:enumeration value="Optional"/>
            <xsd:enumeration value="Conditional"/>
        </xsd:restriction>
    </xsd:simpleType>

    <xsd:simpleType name="MultiplicityStringType">
        <xsd:restriction base="xsd:string">
            <xsd:pattern value="\[[0-9]+\.\.([0-9]+|n|\*)\]"/>
        </xsd:restriction>
    </xsd:simpleType>

    <xsd:complexType name="ObligationType">
        <xsd:simpleContent>
            <xsd:extension base="ded:ObligationEnumType">
                <xsd:attributeGroup ref="ism:SecurityAttributesGroup"/>
            </xsd:extension>
        </xsd:simpleContent>
    </xsd:complexType>

</xsd:schema>
