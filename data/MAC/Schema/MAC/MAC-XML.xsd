                    </xhtml:li>
                </xhtml:ul>
            </xhtml:p>
        </xsd:documentation>
        <xsd:documentation>
            <xhtml:h2 ism:ownerProducer="USA" ism:classification="U">Creators</xhtml:h2>
            <xhtml:p ism:ownerProducer="USA" ism:classification="U">Office of the Director of National Intelligence
                Intelligence Community Chief Information Officer</xhtml:p>
        </xsd:documentation>
    </xsd:annotation>
    <!--***************************************************-->
    <!--Start Import Statements-->
    <!--***************************************************-->
    <xsd:import namespace="urn:us:gov:ic:cvenum:mac:collectionType" 
        schemaLocation="./CVEGenerated/CVEnumMacCollectionType.xsd"/>
    <xsd:import namespace="urn:us:gov:ic:mime" 
        schemaLocation="../MIME/MIME.xsd"/>
    <!--***************************************************-->
    <!--End Import Statements-->
    <!--***************************************************-->
    <!--***************************************************-->
    <!--Start All case-insensitive alphabetically-->
    <!--***************************************************-->

    <xsd:attribute name="DESVersion">
        <xsd:annotation>
            <xsd:documentation xml:lang="en">
                <xhtml:p ism:ownerProducer="USA" ism:classification="U"> The version number of the
                    Data Encoding Specification (DES). Should there be multiple specified in an
                    instance document the one that appears first is the one that will apply to the
                    entire document. </xhtml:p>
            </xsd:documentation>
        </xsd:annotation>
        <xsd:simpleType>
            <xsd:restriction base="xsd:string">
                <xsd:maxLength value="30"/>
                <xsd:pattern value="201609(\-{1,23})?"/>
            </xsd:restriction>
        </xsd:simpleType>
    </xsd:attribute>

    <xsd:element name="MultiAudience">
        <xsd:annotation>
            <xsd:documentation>
                This is the element that would be used in a TDC to denote the TDC as a multi-audience collection.
            </xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
            <xsd:attributeGroup ref="mac:MACRootNodeAttributeGroup"/>
        </xsd:complexType>
    </xsd:element>

    <xsd:element name="MultiAudienceObject">
        <xsd:annotation>
            <xsd:documentation>
                This is the element that would be used in a TDO that is part of a multi-audience collection to relay
                specific information about the TDO relevant to the multi-audience collection.
            </xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
            <xsd:attribute name="original" type="xsd:boolean"/>
            <xsd:attribute ref="mime:mimeType"/>
        </xsd:complexType>
    </xsd:element>

    <xsd:attribute name="multiAudienceType" type="mactype:CVEnumMacCollectionType"/>
    
    <xsd:attributeGroup name="MACRootNodeAttributeGroup">
        <xsd:attribute ref="mac:DESVersion" use="required"/>
        <xsd:attribute ref="mime:CESVersion" use="optional"/>
        <xsd:attribute ref="mac:multiAudienceType"/>
    </xsd:attributeGroup>
    <!--***************************************************-->
    <!--End All case-insensitive alphabetically-->
    <!--***************************************************-->
