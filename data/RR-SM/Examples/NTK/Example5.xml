            <ntk:AccessGroup ism:classification="U" ism:ownerProducer="USA">
                <ntk:AccessSystemName ism:classification="U" ism:ownerProducer="USA">Bob_LDAP</ntk:AccessSystemName>
                <ntk:AccessGroupValue ism:classification="U" ism:ownerProducer="USA">Wheel</ntk:AccessGroupValue>
                <ntk:AccessGroupValue ism:classification="U" ism:ownerProducer="USA">SuperUser</ntk:AccessGroupValue>
            </ntk:AccessGroup>
        </ntk:AccessGroupList>
    </ntk:Access>
    <test:portion ism:classification="U" ism:ownerProducer="USA"
                 ntk:access="Bob_LDAP|Group^Wheel|Group^SuperUser Chris_LDAP|Group^Admin|User^bob"/>
