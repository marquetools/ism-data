<cve:CVE xmlns:cve="urn:us:gov:ic:cve"
         xmlns:ism="urn:us:gov:ic:ism"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         
         ism:compliesWith="USGov USIC"
         ism:ownerProducer="USA"
         ism:classification="U"
         ism:DESVersion="202111"
         ism:ISMCATCESVersion="202205"
         ism:resourceElement="true"
         CVEVersion="2"
         ism:createDate="2015-02-25"
         xsi:schemaLocation="urn:us:gov:ic:cve ../CveSchema/CVEXml.xsd">

    <!-- Change Request #889 - Activity and Sub-Activity Elements  -->
    <cve:IRM>
        <URN xmlns="urn:us:gov:ic:cve">urn:us:gov:ic:cvenum:domex:CVEnumDOMEXActivityPropagandaProductionandDistribution</URN>
        <Title xmlns="urn:us:gov:ic:cve"
             ism:ownerProducer="USA"
             ism:classification="U">CVEnumDOMEXActivityPropagandaProductionandDistribution</Title>
        <Description xmlns="urn:us:gov:ic:cve"
                   ism:ownerProducer="USA"
                   ism:classification="U">Valid range for sub-activities.</Description>

        <cve:Created>2015-02-25</cve:Created>

        <Source ism:classification="U" ism:ownerProducer="USA" xmlns="urn:us:gov:ic:cve">Authoritative source for sub-activities</Source>
        <PointOfContact ism:classification="U" ism:ownerProducer="USA" xmlns="urn:us:gov:ic:cve">
         <Name>DOMEX Metadata Working Group</Name>
      </PointOfContact>
    </cve:IRM>
    
    <cve:Enumeration multivalue="false" ism:ownerProducer="USA" ism:classification="U">
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Actions</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Items related to the production and distribution operations: photos of any set, distribution network, etc.</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">FIS</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Items indicating FIS involvement in a target group's propaganda</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Logo</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Propaganda items that have logos or flags embedded</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Martyrdom</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Propaganda to justify and/or encourage martyrdom</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Other</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Misc items related to primary activity</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Production</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                      ism:classification="U"
                      ism:ownerProducer="USA">Items related to construction of propaganda: preproduction notes, raw video, tools, project files, etc.</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Products</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">Items produced for distribution as propaganda</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Religious</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">Religious propaganda to justify actions</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Reporting</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">Reporting related to propaganda, likely status reports</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">Training</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">Training in using propaganda to support an insurgency or terrorist movement</Description>
        </cve:Term>
        <cve:Term ism:classification="U" ism:ownerProducer="USA">
            <cve:Value ism:classification="U" ism:ownerProducer="USA">US Person</cve:Value>
            <Description xmlns="urn:us:gov:ic:cve"
                ism:classification="U"
                ism:ownerProducer="USA">US Person found in any propaganda related items</Description>
        </cve:Term>
    </cve:Enumeration>
</cve:CVE>
