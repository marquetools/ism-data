	  <!-- MN -->
	  <xs:import namespace="urn:us:gov:ic:mn" schemaLocation="../MN/MN.xsd"/>
	  <xs:import namespace="urn:us:gov:ic:cvenum:mn:issue"
              schemaLocation="../MN/CVEGenerated/CVEnumMNIssue.xsd"/>
