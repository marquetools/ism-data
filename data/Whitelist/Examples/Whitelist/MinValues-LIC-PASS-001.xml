<!-- All classification marks in this example are   -->
<!-- for illustrative purposes only, there are no   -->
<!-- actual classified data contained in this example -->
<!-- 
     Goal:  Passing test of minimum value configuration for NTK License Access Profile
     Test Config File:      ../example_minvalues_config.xml
     Test Config Setting:   <NtkAccessProfile type="minvalues"
                                             accessPolicy="urn:us:gov:ic:aces:ntk:license">
                                <profile vocabulary="datasphere:license" profileValue="osc2" />
                             </NtkAccessProfile>
     Expected Test Result:   PASS
     Expected Error Message: N/A
          
     To run this test:
          1. copy contents of Test Config File to ../../Schematron/Whitelist/whitelist_config.xml
          
     Note: Currently, CVEnumLicLicense.xml only contains a single value, so the effect of @type="minvalues" will be
            the same as @type="whitelist".  To get this rule to fail, there should be no entry for 
            accessPolicy="urn:us:gov:ic:aces:ntk:license" in the config file.  
     
-->
<test:root xmlns:test="test:ntk"
           xmlns:ism="urn:us:gov:ic:ism"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           ism:compliesWith="USGov USIC"
           ism:resourceElement="true"
           ism:createDate="9999-11-11"
           ism:DESVersion="202111.202211"
           ism:ISMCATCESVersion="202211"
           ism:classification="U"
           ism:ownerProducer="USA"
           xsi:schemaLocation="test:ntk ../ISM/test_ntk.xsd">
  <arh:Security xmlns:arh="urn:us:gov:ic:arh"
                ism:classification="U"
                ism:ownerProducer="USA"
                ism:resourceElement="true"
                ism:compliesWith="USGov USIC"
                ism:createDate="2019-12-19">
    <ntk:Access xmlns:ntk="urn:us:gov:ic:ntk"
                ism:classification="U"
                ism:ownerProducer="USA">
      <ntk:RequiresAnyOf>
        <ntk:AccessProfileList>
          <ntk:AccessProfile ism:classification="U"
                             ism:ownerProducer="USA">
            <ntk:AccessPolicy>urn:us:gov:ic:aces:ntk:license</ntk:AccessPolicy>
            <ntk:ProfileDes>urn:us:gov:ic:ntk:profile:datasphere</ntk:ProfileDes>
            <ntk:VocabularyType ntk:name="datasphere:license"
                                ntk:sourceVersion="201508" />
            <ntk:AccessProfileValue ntk:vocabulary="datasphere:license">osc1</ntk:AccessProfileValue>
          </ntk:AccessProfile>
        </ntk:AccessProfileList>
      </ntk:RequiresAnyOf>
    </ntk:Access>
  </arh:Security>
</test:root>
