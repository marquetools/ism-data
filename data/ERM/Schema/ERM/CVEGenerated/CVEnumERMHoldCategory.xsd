            xmlns:xsd="http://www.w3.org/2001/XMLSchema"
            elementFormDefault="qualified"
            xml:lang="en"
            targetNamespace="urn:us:gov:ic:cvenum:erm:holdCategory">
   <xsd:annotation>
      <xsd:documentation>
                    The W3C XML Schema fragment encoding types for CVEnumERMHoldCategory Version 2 controlled vocabulary enumerations. This file is generated, so edits should be made to the CVEnumERMHoldCategory.xml CVE it is based on, instead of here.
                </xsd:documentation>
