        "xsi:schemaLocation": "urn:us:gov:ic:cve ../CveSchema/CVEXml.xsd", 
        "Enumeration": {
            "Term": [
                {
                    "Description": {
                        "text": "A set of system resources that operate in the same security domain and that share the protection of a single, common, continuous security perimeter. (Source: CNSSI 4009)", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "ENCLAVE", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "An application that requires special attention to security due to the risk and magnitude of harm resulting from the loss, misuse, or unauthorized access to or modification of the information in the application. (Source: CNSSI 4009)", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "MAJORAPPLICATION", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "A collection of Information technology (IT), both hardware and software, that is physically part of, dedicated to, or essential in real time to the mission performance of special purpose systems within an identified boundary under the control of a single authority and security policy. The systems may be structured by physical proximity or by function, independent of location. (Source CNSSI 4009)", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "PLATFORMITSYSTEM", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "An interconnected set of information resources under the same direct management control that shares common functionality. It normally includes hardware, software, information, data, applications, communications, and people. (Source: CNSSI 4009)", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "GENERALSUPPORTSYSTEM", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "An IT system entirely comprised of virtual machines", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "VIRTUALITSYSTEM", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "An IT system entirely comprised of containers", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "CONTAINERITSYSTEM", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "An IT system comprosed of bare metal and virtual and/or container elements", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "MIXEDITSYSTEM", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "An IT system that manually and/or automatically provides access and/or transfers information between different security domains.", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "CROSSDOMAIN", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }
            ], 
