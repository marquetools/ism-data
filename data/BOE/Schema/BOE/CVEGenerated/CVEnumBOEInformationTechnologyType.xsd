         <xsd:enumeration value="ENCLAVE">
            <xsd:annotation>
               <xsd:documentation>A set of system resources that operate in the same security domain and that share the protection of a single, common, continuous security perimeter. (Source: CNSSI 4009)</xsd:documentation>
