<CVE xmlns="urn:us:gov:ic:cve" xmlns:ism="urn:us:gov:ic:ism" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    ism:compliesWith="USGov USIC" ism:ownerProducer="USA" ism:classification="U" ism:DESVersion="202111" 
    ism:ISMCATCESVersion="202205" ism:resourceElement="true" CVEVersion="2" specVersion="202111.202205" ism:createDate="2012-11-09" 
    xsi:schemaLocation="urn:us:gov:ic:cve ../CveSchema/CVEXml.xsd">
    <IRM>
    	<URN>urn:us:gov:ic:cvenum:revrecall:action</URN>
    	<Title ism:ownerProducer="USA" ism:classification="U">CVEnumRevRecallAction</Title>
        <Description ism:ownerProducer="USA" ism:classification="U">Actions to be taken for a Revision/Recall.</Description>
    	<cve:Created xmlns:cve="urn:us:gov:ic:cve">2013-12-17T15:52:00-05:00</cve:Created>
        
    	<Source ism:classification="U" ism:ownerProducer="USA">IC-CIO</Source>
    	<PointOfContact ism:classification="U" ism:ownerProducer="USA">
         <Name>Office IC CIO</Name>
         <Email>ic-standards-support@odni.gov</Email>
      </PointOfContact>
    </IRM>
                
   	<Enumeration multivalue="false" ism:ownerProducer="USA" ism:classification="U">
   		
		    <Term ism:classification="U" ism:ownerProducer="USA">
		    	  <Value ism:classification="U" ism:ownerProducer="USA">PURGE</Value>
			      <Description ism:classification="U" ism:ownerProducer="USA">Immediately remove and destroy all copies of the revision of
                the product that has been revised or recalled.</Description>
		    </Term>
   		
   		<Term ism:classification="U" ism:ownerProducer="USA">
   			   <Value ism:classification="U" ism:ownerProducer="USA">RETAIN_WARN</Value>
   			   <Description ism:classification="U" ism:ownerProducer="USA">Retain the existing copies of the revision of the product
                but indicate that it is not the latest revision.</Description>
		    </Term>
   		
   		<Term ism:classification="U" ism:ownerProducer="USA">
   		    <Value ism:classification="U" ism:ownerProducer="USA">RETAIN_HIDE</Value>
   			   <Description ism:classification="U" ism:ownerProducer="USA">Retain the existing copies of the revision of the product
                but prevent access and distribution.</Description>
   		</Term>
        <Term ism:classification="U" ism:ownerProducer="USA">
            <Value ism:classification="U" ism:ownerProducer="USA">MANUAL_INSTRUCTION</Value>
            <Description ism:classification="U" ism:ownerProducer="USA">The action to be taken as a result of the
                revision or recall requires manual intervention by a human to read and follow the
                included instructions.</Description>
        </Term>
   		
   	</Enumeration>
</CVE>