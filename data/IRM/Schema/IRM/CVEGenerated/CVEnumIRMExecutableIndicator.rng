<?xml version="1.0" encoding="UTF-8"?>
<!--UNCLASSIFIED-->
<grammar xmlns="http://relaxng.org/ns/structure/1.0"
         ns="urn:us:gov:ic:cvenum:irm:executableindicator">
   <define name="CVEnumIRMExecutableIndicator.cve">
      <choice>
         <value>Executable</value>
         <value>Indeterminate</value>
         <value>NonExecutable</value>
         <value>Unevaluated</value>
      </choice>
   </define>
</grammar>
